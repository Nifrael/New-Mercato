<div class="form-container black">
  <h1 id="title">CREER UN COMPTE</h1>
  <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= f.error_notification %>
    <div class="form-inputs">
      <%= f.input :first_name,
                label: false,
                placeholder: "PRENOM",
                required: true,
                autofocus: true,
                input_html: { autocomplete: "First name", class: "form-input" },
                label_html: { class: "form-label" } %>
      <%= f.input :last_name,
                label: false,
                placeholder: "NOM",
                required: true,
                autofocus: true,
                input_html: { autocomplete: "Last name", class: "form-input" },
                label_html: { class: "form-label" } %>
      <%= f.input :email,
                label: false,
                required: true,
                autofocus: true,
                placeholder: "EMAIL",
                input_html: { autocomplete: "email", class: "form-input" }%>
      <%= f.input :password,
                label: false,
                required: true,
                placeholder: "MOT DE PASSE",
                hint: ("#{@minimum_password_length} caractères minimum." if @minimum_password_length),
                input_html: { autocomplete: "new-password", class: "form-input" } %>
      <%= f.input :password_confirmation,
                label: false,
                required: true,
                placeholder: "CONFIRMATION DU MOT DE PASSE",
                input_html: { autocomplete: "new-password", class: "form-input" } %>
    </div>
    <div class="form-actions">
      <%= f.button :submit, "CRÉER UN COMPTE" %>
    </div>
  <% end %>
  <%= render "devise/shared/links" %>
</div>
