<header>
  <nav>
    <ul>
      <li>
        <%= link_to players_path do %>
          <%= image_tag('Logo.png') %>
        <% end %>
      </li>
      <%= link_to root_path do %>
        <li>Accueil</li>
      <% end %>
      <li>Statistiques</li>
      <% if user_signed_in? %>
        <li><%= link_to "Dashboard", dashboards_path, class: "dropdown-item" %>
        </li>
        <li><%= link_to "Déconnexion", destroy_user_session_path, data:{turbo_method: :delete} %>
