<div class="search-bar">
  <%= form_with url: players_path, method: :get do %>
    <%= text_field_tag :query,
            params[:query],
            class: "form-control",
            placeholder: "Quelle poste souhaitez-vous renforcer ?"
        %>
    <%= submit_tag "Chercher", name: "Position", class: "btn mt-3" %>
  <% end %>
</div>
